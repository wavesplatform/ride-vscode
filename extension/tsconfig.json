{
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "out",
		"rootDir": "src",
		"lib": [ "es6","dom", "es2015" ],
		"types": [ "node" ],
		"jsx": "react",
		"sourceMap": true,
		"skipLibCheck": true
	},
	"include": [
		"src"
	],
	"exclude": [
        "node_modules",
	]
}
